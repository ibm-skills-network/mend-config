{
  "settingsInheritedFrom": "ibm-mend-config/mend-config@main",
  "overrideConfigAllowList": null,
  "scanSettings": {
    "configMode": "EXTERNAL",
    "configExternalURL": "https://raw.githubusercontent.com/ibm-skills-network/mend-config/main/whitesource.config",
    "exploitability": true
  },
  "checkRunSettings": {
    "strictMode": "warning",
    "strictModeInfo": true
  },
  "remediateSettings": {
    "enableRenovate": true,
    "schedule": ["* 0-7 * * 1-5", "* 18-23 * * 1-5", "* * * * 0,6"],
    "timezone": "America/Toronto",
    "extends": [
      "config:recommended",
      ":disableMajorUpdates",
      "docker:disable"
    ],
    "transitiveRemediation": true
  },
  "scanSettingsSAST": {
    "enableScan": true,
    "scanPullRequests": true,
    "incrementalScan": true,
    "baseBranches": [
      "main",
      "master"
    ],
    "snippetSize": 20
  },
  "checkRunSettingsSAST": {
    "checkRunConclusionLevel": "failure",
    "severityThreshold": "high"
  },
  "issueSettingsSAST": {
    "issueType": "repo",
    "minSeverityLevel": "high"
  }
}
